# Local Postgres (docker compose up -d): postgres://afterhours:afterhours@localhost:5432/afterhours
# Hosted (Neon, Supabase, etc.): paste the pooled connection string (sslmode=require).
DATABASE_URL="postgresql://afterhours:afterhours@localhost:5432/afterhours"

AUTH_SECRET="dev-secret-change-in-prod"
# Auth.js v5 — set in production to your public site URL (Netlify).
# AUTH_URL="https://your-site.netlify.app"

# Public site URL (used in emails / links). Must match AUTH_URL in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Open sign-in (pick at least one for production) ---
# Google — any Google user can sign in / sign up when these are set:
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# Magic link — any email address; requires a working SMTP (e.g. Resend, SendGrid):
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="AfterHours <noreply@yourdomain.com>"

# --- Local / demo only (restricted emails + shared password) ---
# Optional: single fixed account
ALLOWED_LOGIN_EMAIL=""
ALLOWED_LOGIN_PASSWORD=""

DEMO_LOGIN_PASSWORD="afterhours-demo"
DEMO_LOGIN_EMAILS="alex@demo.afterhours.local,sam@demo.afterhours.local,jordan@demo.afterhours.local,riley@demo.afterhours.local,casey@demo.afterhours.local,morgan@demo.afterhours.local"

# Discovery: auto-upsert demo venues/groups on each request (default on in dev, off in production).
# Production: use `npm run db:seed` or set AFTERHOURS_AUTO_SEED_DISCOVERY=true for demo installs.
# AFTERHOURS_AUTO_SEED_DISCOVERY="false"
