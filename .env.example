# --- Local development ---
# Local Postgres (docker compose up -d) or hosted (Neon, etc.) connection string.
DATABASE_URL="postgresql://afterhours:afterhours@localhost:5432/afterhours"

AUTH_SECRET="dev-secret-change-in-prod"

# Public URL for metadata / sitemap / robots. On Vercel, VERCEL_URL is used if this is unset.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Required on Vercel (Production) — copy values into Project → Environment Variables ---
# AUTH_URL="https://your-project.vercel.app"
# (Use your real deployment URL or custom domain; no trailing slash.)

# Email + password: /auth/signup and /auth/signin (no OAuth required).
# Optional — Google and/or magic link:
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="AfterHours <noreply@yourdomain.com>"

# Optional: password for seeded local demo users (@demo.afterhours.local). Default: afterhours-demo
# SEED_DEMO_LOGIN_PASSWORD="afterhours-demo"

# Discovery demo auto-seed (default off in production). Set true only for demos.
# AFTERHOURS_AUTO_SEED_DISCOVERY="false"
