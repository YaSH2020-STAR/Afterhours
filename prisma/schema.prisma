generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— NextAuth (Auth.js) ———

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ——— App ———

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  bio                 String?
  city                String?
  timezone            String?
  /// Saved from device geolocation — used for venue distance (not shared with other users as raw coords in UI).
  latitude            Float?
  longitude           Float?
  onboardingCompleted Boolean   @default(false)
  verified            Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  preferences         UserPreferences?
  memberships         PodMembership[]
  messagesSent        Message[]         @relation("MessageSender")
  messagesReceived    Message[]         @relation("MessageRecipient")
  attendance          Attendance[]
  blocksInitiated     Block[]           @relation("Blocker")
  blocksReceived      Block[]           @relation("Blocked")
  reportsMade         Report[]          @relation("Reporter")
  reportsReceived     Report[]          @relation("Reported")
  seasonEndResponses  SeasonEndResponse[]

  venueRSVPs              VenueRSVP[]
  groupJoins              GroupJoin[]
  discoveryMessages       DiscoveryGroupMessage[] @relation("DiscoveryMsgSender")
  interestGroupsCreated   InterestGroup[]         @relation("InterestGroupCreator")
}

/// Partner venue — recurring “open table” social hours
model OpenTableVenue {
  id             String @id @default(cuid())
  name           String
  description    String?
  city           String
  neighborhood   String?
  address        String?
  latitude       Float?
  longitude      Float?
  scheduleLabel  String
  startTimeLocal String?
  endTimeLocal   String?
  seatTotal      Int
  reservedCount  Int    @default(0)
  checkedInCount Int    @default(0)
  vibesJson      String
  hostLabel      String?
  distanceLabel  String?
  /// active | inactive
  venueStatus    String   @default("active")
  createdAt      DateTime @default(now())

  rsvps VenueRSVP[]
}

model VenueRSVP {
  id        String         @id @default(cuid())
  userId    String
  venueId   String
  status    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     OpenTableVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  updatedAt DateTime       @updatedAt

  @@unique([userId, venueId])
}

model InterestGroup {
  id            String   @id @default(cuid())
  title         String
  category      String
  city          String
  neighborhood  String?
  address       String?
  locationLabel String
  startsAt      DateTime
  endsAt        DateTime?
  minPeople     Int
  maxPeople     Int
  joinedCount   Int      @default(0)
  waitlistCount Int      @default(0)
  vibe          String
  intensity     String
  description   String?
  isPublic      Boolean  @default(true)
  chatEnabled   Boolean  @default(true)
  chatExpiresAt DateTime?
  /// open | full | completed | cancelled
  groupStatus   String   @default("open")
  creatorUserId String?
  creator       User?    @relation("InterestGroupCreator", fields: [creatorUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  joins    GroupJoin[]
  messages DiscoveryGroupMessage[]
}

model GroupJoin {
  id       String        @id @default(cuid())
  userId   String
  groupId  String
  status   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    InterestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt DateTime      @default(now())

  @@unique([userId, groupId])
}

model DiscoveryGroupMessage {
  id        String        @id @default(cuid())
  groupId   String
  senderId  String
  body      String
  createdAt DateTime      @default(now())
  group     InterestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User          @relation("DiscoveryMsgSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

model UserPreferences {
  id                   String      @id @default(cuid())
  userId               String      @unique
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityJson     String
  interestsJson        String
  energyLevel          String @default("MEDIUM")
  groupStyle           String @default("MIXED")
  lifeStagesJson       String
  accessibilityNotes   String?
  languagePreference   String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Pod {
  id               String   @id @default(cuid())
  name             String
  city             String
  weeklySlotLabel  String
  timezone         String   @default("America/New_York")
  /// 0–1 score: overlap + preference fit (demo heuristic)
  healthScore      Float    @default(0.82)
  createdAt        DateTime @default(now())

  seasons          Season[]
  memberships      PodMembership[]
  messages         Message[]
  attendance       Attendance[]
}

model Season {
  id        String       @id @default(cuid())
  podId     String
  pod       Pod          @relation(fields: [podId], references: [id], onDelete: Cascade)
  label     String?
  startDate DateTime
  endDate   DateTime?
  status    String @default("ACTIVE")

  endResponses SeasonEndResponse[]

  @@index([podId])
}

model PodMembership {
  id       String   @id @default(cuid())
  userId   String
  podId    String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod      Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, podId])
}

model Message {
  id          String   @id @default(cuid())
  podId       String
  pod         Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?    @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  body        String
  createdAt   DateTime @default(now())

  @@index([podId, createdAt])
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  podId     String
  weekIndex Int
  status    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod       Pod              @relation(fields: [podId], references: [id], onDelete: Cascade)
  updatedAt DateTime         @updatedAt

  @@unique([userId, podId, weekIndex])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reportedUserId String
  podId          String?
  reason         String
  reporter       User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported       User     @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model SeasonEndResponse {
  id        String          @id @default(cuid())
  userId    String
  seasonId  String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  season    Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  choice    String
  createdAt DateTime        @default(now())

  @@unique([userId, seasonId])
}

/// Legacy marketing waitlist (optional)
model WaitlistSubmission {
  id               String   @id @default(cuid())
  email            String   @unique
  city             String?
  timezone         String?
  situationsJson   String?
  availabilityJson String?
  affinityJson     String?
  comfortNotes     String?
  podVibe          String?
  consentAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

